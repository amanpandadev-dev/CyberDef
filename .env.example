# AegisNet Environment Configuration

# Application
APP_NAME=AegisNet
APP_VERSION=0.1.0
DEBUG=true

# API Server
API_HOST=127.0.0.1
API_PORT=8000

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/aegisnet.db

# Processing
MAX_FILE_SIZE_MB=500
CHUNK_TIME_WINDOW_MINUTES=30
MAX_EVENTS_PER_BATCH=10000

# Agent Configuration
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
MIN_CONFIDENCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# Authentication
# Multi-user mode (recommended):
# Valid usernames are generated as "<AUTH_USERNAME_PREFIX><emp_id>"
# Example with defaults: soc.1001, soc.1002, soc.1003
AUTH_USERNAME_PREFIX=soc.
AUTH_EMP_IDS=1001,1002,1003
AUTH_EMP_NAME_MAP=1001:Alice,1002:Bob,1003:Charlie
AUTH_COMMON_PASSWORD=admin123

# Legacy single-user mode (used only if AUTH_EMP_IDS is empty)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
AUTH_SECRET_KEY=replace-this-secret-for-production
AUTH_TOKEN_TTL_MINUTES=480

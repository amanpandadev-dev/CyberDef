# AegisNet Environment Configuration

# Application
APP_NAME=AegisNet
APP_VERSION=0.1.0
DEBUG=false

# API Server
API_HOST=127.0.0.1
API_PORT=8000

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1

# Database - SQLite (built-in)
DATABASE_URL=sqlite:///./data/aegisnet.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# Processing - Optimized for 45MB files
MAX_FILE_SIZE_MB=100
CHUNK_TIME_WINDOW_MINUTES=15
MAX_EVENTS_PER_BATCH=5000

# Agent Configuration
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
MIN_CONFIDENCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
